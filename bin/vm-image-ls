set -eo pipefail

image_cfg_dir="${XDG_CONFIG_HOME:-$HOME/.config}/little-helpers-vm-images"
mkdir -p "$image_cfg_dir"
for image_path in "$image_cfg_dir"/*; do
    basename "$image_path"
done
